{
  "expo": {
    "name": "ALP",
    "slug": "labora-mobile",
    "version": "1.0.0",
    "scheme": "alp",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
  "image": "./assets/splash.png",
  "resizeMode": "contain",
  "backgroundColor": "#15803d"
},
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.aizue.labora",
      "buildNumber": "4",
      "infoPlist": {
  "NSPhotoLibraryUsageDescription": "ALP Jobs uses your photo library so you can upload a profile photo, CV/resume, or job-related documents when editing your profile or applying for a job.",
  "NSLocationWhenInUseUsageDescription": "ALP Jobs uses your location to show job vacancies near you on the map, for example jobs close to your current area.",
  "NSLocationAlwaysAndWhenInUseUsageDescription": "ALP Jobs uses your location to show job vacancies near you on the map, for example jobs close to your current area.",
  "ITSAppUsesNonExemptEncryption": false
}

    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#15803d"
      },
      "package": "com.aizue.labora",
      "versionCode": 2,
      "googleServicesFile": "./google-services.json",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#15803d"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ff70999b-baec-4479-8c2b-b9f21fae78d6"
      }
    },
    "owner": "aizue"
  }
}
