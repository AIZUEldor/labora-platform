{
  "expo": {
    "name": "ALP Jobs",
    "slug": "labora-mobile",
    "version": "1.0.0",
    "scheme": "alp",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#15803d"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aizue.labora",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "ALP Jobs uses your photo library so you can upload a profile photo, CV/resume, or job-related documents.",
        "NSLocationWhenInUseUsageDescription": "ALP Jobs uses your location to show nearby job vacancies and help you find jobs around your area.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "ALP Jobs uses your location to show nearby job vacancies and help you find jobs around your area.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#15803d"
      },
      "package": "com.aizue.labora",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#15803d"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ff70999b-baec-4479-8c2b-b9f21fae78d6"
      }
    },
    "owner": "aizue"
  }
}
